<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:orientation="horizontal"
            android:paddingTop="36dp"
            android:paddingBottom="16dp"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="New Task"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="8dp" />

        </LinearLayout>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Task Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Task Name"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTaskName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="What do you need to do?"
                        android:inputType="textCapSentences"
                        android:textSize="15sp"
                        android:imeOptions="actionDone" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Date"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnPickDate"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="6dp"
                    android:text="Today"
                    android:textSize="15sp"
                    android:textColor="@color/primary"
                    android:drawableStart="@drawable/ic_calendar"
                    android:drawablePadding="10dp"
                    android:background="@drawable/btn_outline" />

                <!-- Repeat -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Repeat"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp" />

                <Spinner
                    android:id="@+id/spinnerRepeat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp" />

                <!-- Weekly day picker — shown only when "Weekly (specific days)" is selected -->
                <LinearLayout
                    android:id="@+id/layoutWeeklyDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Repeat on"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- Row of day toggles -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center">

                        <CheckBox android:id="@+id/chkSun"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="S" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                        <CheckBox android:id="@+id/chkMon"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="M" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                        <CheckBox android:id="@+id/chkTue"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="T" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                        <CheckBox android:id="@+id/chkWed"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="W" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                        <CheckBox android:id="@+id/chkThu"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="T" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                        <CheckBox android:id="@+id/chkFri"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="F" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                        <CheckBox android:id="@+id/chkSat"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:button="@null"
                            android:background="@drawable/day_toggle_selector"
                            android:text="S" android:textSize="13sp"
                            android:textColor="@color/primary"
                            android:padding="6dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- Save Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:elevation="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnSaveTask"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Task"
                android:textSize="16sp"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>